# Token de @BotFather (obligatorio)
BOT_TOKEN=tu_token_aqui

# Base de datos SQLite
# Local: linkedin_bot.db
# Railway con volumen en /data: /data/linkedin_bot.db
DATABASE_PATH=linkedin_bot.db

# Búsqueda automática (valores por defecto para usuarios nuevos)
CHECK_INTERVAL_HOURS=12
LIMIT_RESULTS=25

# Proveedor de IA (opcional, para análisis y cartas de presentación)
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b

XAI_API_KEY=
XAI_MODEL=grok-3-mini