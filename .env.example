# ============================================
# TELEGRAM (obligatorio)
# ============================================
# Crea tu bot en https://t.me/BotFather y pega el token aqui
BOT_TOKEN=tu_token_aqui

# ============================================
# BASE DE DATOS
# ============================================
# Local: linkedin_bot.db
# Railway con volumen en /data: /data/linkedin_bot.db
DATABASE_PATH=linkedin_bot.db

# ============================================
# BUSQUEDA AUTOMATICA
# ============================================
CHECK_INTERVAL_HOURS=12
LIMIT_RESULTS=25

# ============================================
# PROVEEDOR DE IA
# ============================================
# Opciones: auto | openai | gemini | grok | venice | custom
# auto = usa la primera API key que encuentre
AI_PROVIDER=auto

# --- ChatGPT (OpenAI) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (Google) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Grok (xAI) ---
# https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# --- Venice AI ---
# https://venice.ai/settings/api
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b

# --- Cualquier API compatible con OpenAI ---
# DeepSeek, Mistral, OpenRouter, Ollama, etc.
AI_API_BASE_URL=https://api.ejemplo.com/v1
AI_API_KEY=
AI_MODEL=nombre-del-modelo